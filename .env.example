# 大语言模型支持智谱AI，兼容OpenAI SDK的api和Ollama封装的本地api
# 大语言模型的url地址
LLM_BASE_URL = https://open.bigmodel.cn/api/paas/v4
# LLM_BASE_URL = https://api.deepseek.com/v1
# LLM_BASE_URL = https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_BASE_URL = https://api.siliconflow.cn/v1
# LLM_BASE_URL = https://ark.cn-beijing.volces.com/api/v3
# LLM_BASE_URL = http://127.0.0.1:11434/v1

# 大语言模型的api key
LLM_API_KEY = 
# 大语言模型的名称
MODEL_NAME = glm-4-flash
# 可选 glm-4-flash, glm-4-plus, 
# deepseek-chat, deepseek-reasoner, 
# qwen-max, qwen2.5-7b-instruct-1m
# doubao-1-5-pro-32k

# yaml配置文件的选择，web指config/config-web.yaml
PY_ENVIRONMENT = web

# 医学RAG离线入库配置
MILVUS_URI = http://127.0.0.1:19530
MILVUS_TIMEOUT = 10
MEDICAL_TEXTBOOK_COLLECTION = medical_textbooks
MEDICAL_CHUNKS_DIR = E:\华大医疗agent清洗版chunks
BGE_M3_MODEL = D:\models\huggingface\hub\models--BAAI--bge-m3
BGE_M3_DEVICE = auto
BGE_M3_BATCH_SIZE = 16
BGE_M3_MAX_LENGTH = 1024
BGE_M3_USE_FP16 = 1
MEDICAL_RETRIEVE_TOP_K = 12
MEDICAL_RETRIEVE_CANDIDATE_K = 40
MEDICAL_DENSE_WEIGHT = 0.7
MEDICAL_SPARSE_WEIGHT = 0.3

# 图片生成模型api地址，目前只支持ZhipuAI
IMAGE_GENERATE_API = 
# 图片生成模型的名称
IMAGE_GENERATE_MODEL = cogview-3-flash

# 多模态（图片理解）大模型api地址，目前只支持ZhipuAI
IMAGE_DESCRIBE_API = 
# 多模态（图片理解）大模型的名称
IMAGE_DESCRIBE_MODEL = glm-4v-flash

